# IES Programme Control Platform — frontend environment
# Copy to .env.local for local development. All VITE_* vars are exposed to the
# browser bundle by design; never put service-role / secret keys here.

# Supabase project REST URL
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase PUBLISHABLE key (sb_publishable_...). Public by design — protected by RLS.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Shared demo password for the 9-account roster (one-click role switcher).
VITE_DEMO_PASSWORD=IESdemo2026!

# Optional: Sentry DSN for error tracking. Leave blank to disable.
VITE_SENTRY_DSN=
